{
  "name": "cs-tipitaka",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0 <26"
  },
  "scripts": {
    "prebuild": "node --experimental-strip-types scripts/build-corpus.ts",
    "predev": "node --eval \"require('fs').existsSync('lib/corpus/generated/corpus-tree.json')||require('child_process').execSync('npm run prebuild',{stdio:'inherit'})\"",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "fix-all": "npm run lint:fix && npm run format",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@opennextjs/cloudflare": "^1.19.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.79.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.9",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "fast-xml-parser": "^5.9.2",
    "prettier": "^3.8.4",
    "tailwindcss": "^4",
    "typescript": "^6.0.3",
    "wrangler": "^4.103.0"
  }
}
