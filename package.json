{
  "name": "cs-tipitaka",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=20.9.0 <26"
  },
  "scripts": {
    "dev": "pnpm run dev:legacy-next",
    "dev:legacy-next": "pnpm --filter @cs-tipitaka/legacy-next --fail-if-no-match run dev",
    "dev:web": "pnpm --filter @cs-tipitaka/web --fail-if-no-match run dev",
    "dev:api": "pnpm --filter @cs-tipitaka/api --fail-if-no-match run dev",
    "build": "pnpm run build:legacy-next",
    "build:legacy-next": "pnpm --filter @cs-tipitaka/legacy-next --fail-if-no-match run build",
    "build:web": "pnpm --filter @cs-tipitaka/web --fail-if-no-match run build",
    "build:api": "pnpm --filter @cs-tipitaka/api --fail-if-no-match run build",
    "lint": "pnpm --filter @cs-tipitaka/legacy-next --fail-if-no-match run lint",
    "lint:fix": "pnpm --filter @cs-tipitaka/legacy-next --fail-if-no-match run lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "fix-all": "pnpm run lint:fix && pnpm run format",
    "fix-all:legacy-next": "pnpm --filter @cs-tipitaka/legacy-next --fail-if-no-match run fix-all",
    "fix-all:web": "pnpm --filter @cs-tipitaka/web --fail-if-no-match run fix-all",
    "fix-all:api": "pnpm --filter @cs-tipitaka/api --fail-if-no-match run fix-all",
    "preview": "pnpm --filter @cs-tipitaka/legacy-next --fail-if-no-match run preview",
    "deploy": "pnpm --filter @cs-tipitaka/legacy-next --fail-if-no-match run deploy",
    "file-length": "./file_length.sh"
  },
  "devDependencies": {
    "prettier": "^3.8.4"
  }
}
