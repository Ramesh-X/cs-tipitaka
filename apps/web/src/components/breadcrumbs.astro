---
import { site } from '@/lib/site';
import JsonLd from '@/components/json-ld.astro';
import Pali from '@/components/reader/pali.astro';
import { cn } from '@/lib/utils';
import { titleIsPali } from '@/lib/corpus';
import type { Crumb } from '@/lib/corpus';

interface Props {
  crumbs: Crumb[];
  class?: string;
}

const { crumbs, class: className } = Astro.props;

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: site.url,
    },
    ...crumbs.map((crumb, i) => ({
      '@type': 'ListItem',
      position: i + 2,
      name: crumb.title,
      item: `${site.url}${crumb.href}`,
    })),
  ],
};
---

<JsonLd data={breadcrumbJsonLd} />

<nav
  aria-label="Breadcrumb"
  class={cn('flex items-center gap-1 text-sm', className)}
>
  <ol class="flex flex-wrap items-center gap-1">
    <li class="flex items-center gap-1">
      <a
        href="/"
        class="flex items-center text-muted-foreground transition-colors hover:text-foreground"
        aria-label="Home"
      >
        <!-- home icon -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="size-4"
          aria-hidden="true"
        >
          <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
          <polyline points="9 22 9 12 15 12 15 22"></polyline>
        </svg>
      </a>
    </li>

    {
      crumbs.map((crumb, i) => {
        const isLast = i === crumbs.length - 1;
        const showPali = !titleIsPali(crumb.title, crumb.pali);
        return (
          <>
            <li aria-hidden="true" class="text-muted-foreground/50">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="size-3.5"
                aria-hidden="true"
              >
                <path d="m9 18 6-6-6-6" />
              </svg>
            </li>
            <li class="flex items-center gap-1">
              {isLast ? (
                <span aria-current="page" class="font-medium text-foreground">
                  {crumb.title}
                  {showPali && (
                    <span class="ml-1 text-muted-foreground font-normal">
                      (<Pali text={crumb.pali} />)
                    </span>
                  )}
                </span>
              ) : (
                <a
                  href={crumb.href}
                  class="text-muted-foreground transition-colors hover:text-foreground"
                >
                  {crumb.title}
                  {showPali && (
                    <span class="ml-1 text-muted-foreground/70">
                      (<Pali text={crumb.pali} />)
                    </span>
                  )}
                </a>
              )}
            </li>
          </>
        );
      })
    }
  </ol>
</nav>
