---
import { Badge } from '@/components/ui/badge';
import Pali from '@/components/reader/pali.astro';
import {
  isDocument,
  nodeTypeLabel,
  secondaryPali,
  titleIsPali,
  childSummary,
  type CorpusNode,
} from '@/lib/corpus';
import { cn } from '@/lib/utils';

interface Props {
  nodes: CorpusNode[];
  basePath: string;
}

const { nodes, basePath } = Astro.props;

function cardHref(node: CorpusNode): string {
  return `${basePath}/${node.slug}`;
}
---

{
  nodes.length === 0 ? (
    <p class="py-8 text-center text-muted-foreground">
      No sections available yet.
    </p>
  ) : (
    <ul class="grid gap-4 sm:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4">
      {nodes.map((node) => {
        const pali = secondaryPali(node.title, node.pali);
        const isPali = titleIsPali(node.title, node.pali);
        const summary = childSummary(node);
        const href = cardHref(node);
        const docNode = isDocument(node);
        return (
          <li>
            <a
              href={href}
              class={cn(
                'group flex h-full flex-col gap-3 rounded-lg border border-border bg-card p-4',
                'transition-colors hover:border-primary/40 hover:bg-accent/30',
              )}
            >
              <div class="flex items-start justify-between gap-2">
                <div class="flex items-center gap-2">
                  {docNode ? (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="size-4 shrink-0 text-muted-foreground"
                      aria-hidden="true"
                    >
                      <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z" />
                      <path d="M14 2v4a2 2 0 0 0 2 2h4" />
                      <path d="M10 9H8" />
                      <path d="M16 13H8" />
                      <path d="M16 17H8" />
                    </svg>
                  ) : (
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      class="size-4 shrink-0 text-muted-foreground"
                      aria-hidden="true"
                    >
                      <path d="M20 10a1 1 0 0 0 1-1V6a1 1 0 0 0-1-1h-2.5a1 1 0 0 1-.8-.4l-.9-1.2A1 1 0 0 0 15 3h-2a1 1 0 0 0-1 1v5a1 1 0 0 0 1 1Z" />
                      <path d="M20 21a1 1 0 0 0 1-1v-3a1 1 0 0 0-1-1h-2.9a1 1 0 0 1-.88-.55l-.42-.85a1 1 0 0 0-.92-.6H13a1 1 0 0 0-1 1v5a1 1 0 0 0 1 1Z" />
                      <path d="M3 5a2 2 0 0 0 2 2h3" />
                      <path d="M3 3v13a2 2 0 0 0 2 2h3" />
                    </svg>
                  )}
                  <div class="min-w-0">
                    <span class="block font-medium leading-snug">
                      {node.title}
                    </span>
                    {pali && !isPali && (
                      <span class="block text-sm text-muted-foreground leading-snug">
                        <Pali text={pali} />
                      </span>
                    )}
                  </div>
                </div>
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  class="size-4 shrink-0 text-muted-foreground transition-transform group-hover:translate-x-0.5"
                  aria-hidden="true"
                >
                  <path d="m9 18 6-6-6-6" />
                </svg>
              </div>

              <div class="flex items-center gap-2">
                <Badge variant="secondary">{nodeTypeLabel(node.type)}</Badge>
                <span class="text-xs text-muted-foreground">{summary}</span>
              </div>

              {node.blurb && (
                <p class="line-clamp-3 text-sm text-muted-foreground">
                  {node.blurb}
                </p>
              )}
            </a>
          </li>
        );
      })}
    </ul>
  )
}
