---
import CorpusBrowser from '@/components/corpus-browser.astro';

interface Props {
  currentSlug: string[];
}

const { currentSlug } = Astro.props;
---

<details class="rounded-lg border border-border">
  <summary
    class="flex cursor-pointer select-none list-none items-center gap-2 px-4 py-3 text-sm font-medium [&::-webkit-details-marker]:hidden"
  >
    <!-- book-open icon -->
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="size-4 text-muted-foreground"
      aria-hidden="true"
    >
      <path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path>
      <path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path>
    </svg>
    Browse Tipiṭaka hierarchy
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="ml-auto size-3.5 text-muted-foreground transition-transform in-[details[open]>summary]:rotate-90"
      aria-hidden="true"
    >
      <path d="m9 18 6-6-6-6"></path>
    </svg>
  </summary>
  <div class="border-t border-border p-3">
    <CorpusBrowser currentSlug={currentSlug} bare />
  </div>
</details>
