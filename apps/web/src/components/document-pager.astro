---
import Pali from '@/components/reader/pali.astro';
import { secondaryPali, titleIsPali, type CorpusEntry } from '@/lib/corpus';
import { cn } from '@/lib/utils';

interface Props {
  previous?: CorpusEntry;
  next?: CorpusEntry;
}

const { previous, next } = Astro.props;

if (!previous && !next) {
  return;
}
---

<nav
  aria-label="Document navigation"
  class="grid gap-4 sm:grid-cols-2 border-t border-border pt-6 mt-8"
>
  {
    previous ? (
      <a
        href={previous.href}
        class={cn(
          'group flex flex-col gap-1 rounded-lg border border-border p-4',
          'transition-colors hover:border-primary/40 hover:bg-accent/30',
        )}
      >
        <div class="flex items-center gap-1.5 text-xs text-muted-foreground">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-3.5"
            aria-hidden="true"
          >
            <path d="m12 19-7-7 7-7" />
            <path d="M19 12H5" />
          </svg>
          Previous text
        </div>
        <span class="font-medium leading-snug">{previous.node.title}</span>
        {secondaryPali(previous.node.title, previous.node.pali) &&
          !titleIsPali(previous.node.title, previous.node.pali) && (
            <span class="text-sm text-muted-foreground">
              <Pali text={previous.node.pali} />
            </span>
          )}
      </a>
    ) : (
      <div />
    )
  }

  {
    next && (
      <a
        href={next.href}
        class={cn(
          'group flex flex-col gap-1 rounded-lg border border-border p-4 text-right',
          'transition-colors hover:border-primary/40 hover:bg-accent/30',
          !previous && 'sm:col-start-2',
        )}
      >
        <div class="flex items-center justify-end gap-1.5 text-xs text-muted-foreground">
          Next text
          <svg
            xmlns="http://www.w3.org/2000/svg"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="size-3.5"
            aria-hidden="true"
          >
            <path d="M5 12h14" />
            <path d="m12 5 7 7-7 7" />
          </svg>
        </div>
        <span class="font-medium leading-snug">{next.node.title}</span>
        {secondaryPali(next.node.title, next.node.pali) &&
          !titleIsPali(next.node.title, next.node.pali) && (
            <span class="text-sm text-muted-foreground">
              <Pali text={next.node.pali} />
            </span>
          )}
      </a>
    )
  }
</nav>
