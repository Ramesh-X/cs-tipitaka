---
import Pali from '@/components/reader/pali.astro';
import { classifyRend, type RendClass } from '@/components/reader/rend.ts';
import type { Paragraph } from '@/lib/corpus';
import { cn } from '@/lib/utils';

interface Props {
  paragraph: Paragraph;
  prevClass: RendClass | null;
}

const { paragraph: p, prevClass } = Astro.props;

const rc = classifyRend(p.rend);
const isVerse = rc === 'verse';

// Top gap for body/verse paragraphs
function topGap(): string {
  if (isVerse) return prevClass === 'verse' ? 'mt-0' : 'mt-5';
  if (p.num) return 'mt-6';
  return 'mt-2';
}
---

{
  rc === 'banner' && (
    <div id={p.id} class="group relative mt-2 scroll-mt-32 first:mt-0">
      <p class="text-center font-reading text-sm font-medium tracking-wide text-muted-foreground uppercase">
        <Pali text={p.pali} />
      </p>
    </div>
  )
}

{
  rc === 'chapter' && (
    <div id={p.id} class="group relative mt-10 mb-2 scroll-mt-32 first:mt-0">
      <h2 class="text-center font-reading text-2xl font-semibold tracking-tight">
        <Pali text={p.pali} />
      </h2>
    </div>
  )
}

{
  rc === 'subhead' && (
    <div id={p.id} class="group relative mt-12 mb-1 scroll-mt-32 first:mt-0">
      <div class="flex items-center gap-4">
        <span class="h-px flex-1 bg-border" aria-hidden="true" />
        <h3 class="text-center font-reading text-xl font-semibold tracking-tight">
          <Pali text={p.pali} />
        </h3>
        <span class="h-px flex-1 bg-border" aria-hidden="true" />
      </div>
    </div>
  )
}

{
  rc === 'subsubhead' && (
    <div id={p.id} class="group relative mt-6 mb-1 scroll-mt-32 first:mt-0">
      <h4 class="text-center font-reading text-base font-semibold text-foreground/90">
        <Pali text={p.pali} />
      </h4>
    </div>
  )
}

{
  rc === 'centre' && (
    <div id={p.id} class="group relative my-5 scroll-mt-32">
      <p class="text-center font-reading text-sm font-medium text-muted-foreground">
        <Pali text={p.pali} />
      </p>
    </div>
  )
}

{
  (rc === 'body' || rc === 'verse') && (
    <div
      id={p.id}
      class={cn(
        'group relative scroll-mt-32 target:rounded-md target:bg-muted/30',
        topGap(),
      )}
    >
      {/* M4.x: ParaActions mount */}
      <div class="grid gap-x-10 gap-y-2" data-para-body>
        <p class={cn('text-foreground', isVerse && 'pl-6 italic')}>
          {p.num && (
            <span class="mr-1.5 font-semibold tabular-nums text-primary/80">
              {p.num}.
            </span>
          )}
          <Pali text={p.pali} />
        </p>
      </div>
      {(p.cst || p.pts) && (
        <div class="absolute top-full left-0 z-10 mt-0.5 flex items-center gap-2 text-[0.7em] text-muted-foreground opacity-0 transition-opacity group-hover:opacity-100">
          {p.cst && <span class="font-mono">CST {p.cst}</span>}
          {p.pts && <span class="font-mono">PTS {p.pts}</span>}
        </div>
      )}
    </div>
  )
}
