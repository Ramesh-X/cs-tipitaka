{
  "name": "@cs-tipitaka/legacy-next",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.9.0 <26"
  },
  "scripts": {
    "prebuild": "node --experimental-strip-types scripts/build-corpus.ts",
    "predev": "node --eval \"require('fs').existsSync('lib/corpus/generated/corpus-tree.json')||require('child_process').execSync('pnpm run prebuild',{stdio:'inherit'})\"",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write . --config ../../.prettierrc --ignore-path ../../.prettierignore",
    "fix-all": "pnpm run lint:fix && pnpm run format",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@opennextjs/cloudflare": "^1.20.0",
    "@pnfo/pali-converter": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.80.0",
    "server-only": "^0.0.1",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint-config-next": "16.2.9",
    "fast-xml-parser": "^5.9.3",
    "tailwindcss": "^4",
    "typescript": "^6.0.3",
    "wrangler": "^4.104.0"
  }
}
